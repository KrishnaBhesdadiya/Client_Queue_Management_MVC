@model Appointment

<main class="main" id="main">
    <h3 class="fw-bold mb-4" style="color:#0f6d63">Appointment Details</h3>
    <a asp-action="MyAppointments" class="btn bg-secondary-light mb-3">Back to My Appointments</a>

    <div class="card shadow-sm border-0 mb-3" style="max-width: 800px; border-radius: 8px;">
            
            <div class="card-body">
                <h5 class="card-title mb-0 fw-bold">Appointment Details</h5>
                <p><strong>Date:</strong> @Model.appointmentDate</p>
                @* <p><strong>Time Slot:</strong> @Model.timeSlot</p> *@
                @* <p><strong>Status:</strong> @Model.status</p> *@
                @if (Model.queueEntry != null)
                {
                    <p><strong>Token:</strong> @Model.queueEntry.tokenNumber</p>
                <p>
                    <strong>Queue Status:</strong>
                    @if (Model.queueEntry.status == "waiting")
                    {
                        <span class="badge bg-warning-light test-danger">@Model.queueEntry.status</span>
                    }
                    else if (Model.queueEntry.status == "in_progress")
                    {

                        <span class="badge bg-primary-light">@Model.queueEntry.status</span>
                    }
                    else
                    {

                        <span class="badge bg-success-light text-dark">@Model.queueEntry.status</span>
                    }
                </p>
                }
            </div>
    </div>
    <div class="card shadow-sm border-0 mb-3" style="max-width: 800px; border-radius: 8px;">
        <div class="card-body ">
            <h5 class="card-title mb-0 fw-bold">Medical Prescription</h5>
            @if (Model.prescription != null)
            {
                <p><strong>Doctor:</strong> @Model.prescription.doctor</p>
                <p><strong>Notes:</strong> @Model.prescription.notes</p>
            }
            else
            {
                <p class="text-muted">No prescription added for this appointment yet.</p>
            }
        </div>
    </div>
    <div class="card shadow-sm border-0 mb-3" style="max-width: 800px; border-radius: 8px;">
        <div class="card-body">
            <h5 class="card-title mb-0 fw-bold">Medical Report</h5>
            @if (Model.report != null)
            {
                <p><strong>Doctor:</strong> @Model.report.doctor</p>
                <p><strong>Diagnosis:</strong> @Model.report.diagnosis</p>
                <p><strong>Tests Recommended:</strong> @Model.report.testRecommended</p>
                <p><strong>Remarks:</strong> @Model.report.remarks</p>
            }
            else
            {
                <p class="text-muted">No report added for this appointment yet.</p>
            }
        </div>
    </div>
</main>