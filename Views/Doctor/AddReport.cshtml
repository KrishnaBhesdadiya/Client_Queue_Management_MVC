@using ClinicQueueFrontend.Models
@model AddReportModel
@{
    Layout = "_DoctorLayout";
}

<div class="card shadow" style="max-width: 600px; margin: auto;">
    <div class="card-header text-white" style="background-color:#0f6d63">
        <h4 class="mb-0">Add Report</h4>
    </div>
    <div class="card-body">
        <form method="post" asp-action="AddReport">
            <input type="hidden" asp-for="appointmentId" />

            <div class="mb-3">
                <label class="form-label">Diagnosis *</label>
                <input type="text" asp-for="diagnosis" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Tests Recommended</label>
                <input type="text" asp-for="testRecommended" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Remarks</label>
                <textarea asp-for="remarks" class="form-control" rows="3"></textarea>
            </div>

            @if (ViewBag.msg != null)
            {
                <div class="alert alert-danger">@ViewBag.msg</div>
            }

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save Report</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>
